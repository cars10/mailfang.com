---
const demoHost =
  import.meta.env.NODE_ENV === 'development'
    ? 'http://localhost:5173'
    : 'https://demo.mailfang.com'
const demoPath = `${demoHost}/redirect_first_email?reduced=true&demo=true`
---

<div class="flex flex-col md:flex-row">
  <section
    class="p-4 md:p-0 mx-auto md:w-1/3 md:mt-30 text-white 1md:overflow-x-hidden h-[90svh] md:h-auto flex flex-col justify-between md:justify-normal gap-20"
  >
    <h2 class="text-3xl md:text-5xl">
      Mail<span class="font-bold">Fang</span> is your new <span
        class="text-secondary">email</span
      > testing tool.
    </h2>

    <p class="text-2xl font-light leading-12 text-gray-400 max-w-full">
      View your emails in a modern web UI, inspect your data in real-time and
      regain control of your infrastructure.
    </p>

    <div class="flex flex-row gap-4">
      <a href="/quickstart" class="btn btn-secondary"> Quickstart </a>
      <a
        href="https://github.com/cars10/mailfang"
        class="btn btn-dull"
        target="_blank"
      >
        Github
      </a>
    </div>
  </section>

  <section class="p-4 md:w-1/2 mt-10 md:mt-26">
    <iframe src={demoPath} class="w-full md:w-200 h-200 bg-white rounded-sm" allow="clipboard-write"
    ></iframe>
  </section>
</div>
